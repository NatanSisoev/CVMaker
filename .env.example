# Copy to .env (or set these in your shell / your PaaS's secrets panel).
# The .env file is gitignored; this .env.example is the source of truth
# for *which* variables exist. Update both if you add a new one.

# ----------------------------------------------------------------------
# Django core
# ----------------------------------------------------------------------
# Generate a fresh one for every environment:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-fresh-random-key

# True on your laptop, False everywhere else.
DJANGO_DEBUG=True

# Comma-separated. In dev: localhost,127.0.0.1. In prod: your domain.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated full origins including scheme. Prod example:
#   https://cvmaker.app,https://www.cvmaker.app
DJANGO_CSRF_TRUSTED_ORIGINS=

# ----------------------------------------------------------------------
# Database
# Option A (recommended): one URL.
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME
# Option B: individual components (used if DATABASE_URL is unset).
# ----------------------------------------------------------------------
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/cvmaker

DB_NAME=cvmaker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ----------------------------------------------------------------------
# Email
# Dev default prints to the console. In prod, wire a real backend.
# ----------------------------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ----------------------------------------------------------------------
# Production-only hardening (ignored when DJANGO_DEBUG=True)
# ----------------------------------------------------------------------
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
